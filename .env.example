# Environment Variables - AngoLife

# Supabase
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Exchange Rate API (FREE - 1500 requests/mês)
# Cadastre-se em: https://www.exchangerate-api.com/
VITE_EXCHANGERATE_API_KEY=your_exchangerate_api_key_here

# Google Gemini API (opcional - para insights de mercado)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
